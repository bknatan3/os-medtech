generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  GESTOR
  TECNICO
  LEITOR
}

enum WorkOrderStatus {
  RASCUNHO
  ABERTA
  EM_ANDAMENTO
  AGUARDANDO_PECA
  CONCLUIDA
  FECHADA
  CANCELADA
}

model Organization {
  id               String      @id @default(uuid())
  nomeFantasia     String
  razaoSocial      String?
  cnpj             String?
  timezone         String      @default("America/Sao_Paulo")
  sequenceNextOs   Int         @default(1)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  users            User[]
  customers        Customer[]
  equipment        Equipment[]
  templates        WorkOrderTemplate[]
  workOrders       WorkOrder[]
  attachments      WorkOrderAttachment[]
  auditEvents      AuditEvent[]
  syncDevices      SyncDevice[]
  syncMutations    SyncMutation[]
}

model User {
  id          String   @id @default(uuid())
  orgId       String
  name        String
  email       String   @unique
  passwordHash String
  role        Role
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lastLoginAt DateTime?
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model Customer {
  id             String @id @default(uuid())
  orgId          String
  name           String
  cnpj           String?
  address        String?
  contactName    String?
  contactPhone   String?
  contactEmail   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  org            Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  equipment      Equipment[]
  workOrders     WorkOrder[]
}

model Equipment {
  id            String @id @default(uuid())
  orgId         String
  customerId    String
  tipo          String
  fabricante    String
  modelo        String
  numeroSerie   String
  patrimonio    String?
  localizacao   String?
  status        String  @default("ativo")
  observacoes   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  org           Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  workOrders    WorkOrder[]
}

model WorkOrderTemplate {
  id           String @id @default(uuid())
  orgId        String
  name         String
  schemaJson   Json
  version      Int    @default(1)
  active       Boolean @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  workOrders   WorkOrder[]
}

model WorkOrder {
  id                     String @id
  orgId                  String
  numeroOs               Int?
  status                 WorkOrderStatus @default(RASCUNHO)
  prioridade             String @default("MEDIA")
  customerId             String
  equipmentId            String
  criadoPorUserId        String
  atribuidoParaUserId    String?
  descricaoProblema      String?
  diagnostico            String?
  servicoExecutado       String?
  pecasUtilizadasJson    Json?
  tempoGastoMin          Int?
  custo                  Decimal?
  templateId             String?
  templateVersion        Int?
  templateSnapshotJson   Json?
  customValuesJson       Json?
  tecnicoAttachmentId    String?
  clienteAttachmentId    String?
  revision               Int @default(1)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  deletedAt              DateTime?
  org                    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  customer               Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)
  equipment              Equipment @relation(fields: [equipmentId], references: [id], onDelete: Restrict)
  template               WorkOrderTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  attachments            WorkOrderAttachment[]

  @@unique([orgId, numeroOs])
  @@index([orgId, status, updatedAt])
  @@index([orgId, equipmentId])
}

model WorkOrderAttachment {
  id           String @id @default(uuid())
  orgId        String
  workOrderId  String
  tipo         String
  storageKey   String
  mimeType     String?
  size         Int?
  hash         String?
  createdAt    DateTime @default(now())
  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  workOrder    WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
}

model AuditEvent {
  id          String @id @default(uuid())
  orgId       String
  entidade    String
  entidadeId  String
  acao        String
  userId      String?
  deviceId    String?
  diffJson    Json?
  timestamp   DateTime @default(now())
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model SyncDevice {
  id            String @id @default(uuid())
  orgId         String
  userId        String
  deviceId      String
  lastSyncToken String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  org           Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, deviceId])
}

model SyncMutation {
  id           String @id @default(uuid())
  orgId        String
  deviceId     String
  mutationId   String
  processedAt  DateTime @default(now())
  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, deviceId, mutationId])
}
